# ─── Data output (large files, regenerated from scrapers) ─────────────────────
output/*.json
output/*.csv
output/*.gexf
output/*.html
output/*.txt
output/*.log
output/*.npz
output/*.npy

# Keep the output directory structure
!output/.gitkeep

# Saídas geradas em runtime (relatórios, filas, emails)
output/consultorias/
output/email_outbox/
output/_probe/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Node / frontend viewers ─────────────────────────────────────────────────
node_modules/
*/dist/
*/node_modules/

# ─── Virtual environment ─────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Secrets / local config ──────────────────────────────────────────────────
.env
.env.local
*.secret

